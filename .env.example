APP_NAME="Barangay Blotter Tenancy"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=barangay_blotter
DB_USERNAME=root
DB_PASSWORD=

# Placeholder DB name used ONLY when running tenant migrations manually via:
# `php artisan migrate --database=tenant ...`
# Normal tenant provisioning dynamically sets the tenant connection to each
# tenant's own database.
TENANT_DB_DATABASE=barangay_blotter

SESSION_DRIVER=database
SESSION_CONNECTION=central
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Central app login background (shown when no tenant is resolved)
# Example: CENTRAL_LOGIN_BACKGROUND_URL=/images/central-login-bg.jpg
CENTRAL_LOGIN_BACKGROUND_URL=
CENTRAL_LOGIN_BACKGROUND_OPACITY=0.45
CENTRAL_LOGIN_BACKGROUND_BLUR=0

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_CURRENCY=php

TENANCY_BASE_DOMAIN=localhost
TENANCY_BASE_PORT=8000
TENANCY_SUPER_SUBDOMAIN=admin

# System updater (GitHub releases). Local/testing defaults to relaxed TLS for GitHub only; production verifies TLS.
# For strict verify on local: UPDATE_GITHUB_VERIFY_SSL=true and set php.ini curl.cainfo or:
# UPDATE_GITHUB_CURL_CAINFO=C:\path\to\cacert.pem
# UPDATE_GITHUB_HTTP_TIMEOUT_API=120
# UPDATE_GITHUB_HTTP_TIMEOUT_DOWNLOAD=1800
